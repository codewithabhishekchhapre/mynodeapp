<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document</title>
</head>
<body>
  <h1>Hello <%=data%></h1>
  <h2>Signup form</h2>
  <form action="/submit" method="post">
